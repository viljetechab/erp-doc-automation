# ╔══════════════════════════════════════════════════════════════════════╗
# ║  OrderFlow Pro — Backend Environment Configuration                  ║
# ║  Copy this file to .env and fill in the values below.               ║
# ╚══════════════════════════════════════════════════════════════════════╝

# === Required ===
OPENAI_API_KEY=sk-your-openai-api-key-here

# === Application ===
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# === Database ===
# PostgreSQL (required for production/staging):
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/orderflow_pro
# SQLite (local development only — not supported in production):
# DATABASE_URL=sqlite+aiosqlite:///./data/orderflow_pro.db

# === OpenAI ===
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=8192

# === Supplier Defaults ===
# These values are used as fallback when the PDF does not contain supplier info.
# Replace with the actual supplier details for each client deployment.
SUPPLIER_NAME=Demo Supplier Ltd
SUPPLIER_EDI_CODE=0000000
SUPPLIER_STREET=1 Business Street
SUPPLIER_ZIP_CITY=00000 DEMO CITY
SUPPLIER_COUNTRY=Demo Country

# === Auth / JWT ===
# IMPORTANT: Change this to a strong random secret in production!
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === OAuth — Microsoft ===
# Register at: https://portal.azure.com → App Registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:5173/auth/microsoft/callback
MICROSOFT_TENANT_ID=common

# === CORS ===
# JSON array of allowed browser origins (required when the frontend uses cookies / withCredentials).
# In Azure App Service, set the same value under Application settings → CORS_ORIGINS.
# If Azure Portal → API → CORS is configured there, disable it so FastAPI owns CORS (credentials).
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:3000","https://erp-doc-automation-dev-fe-hccze9hedha0g7gc.swedencentral-01.azurewebsites.net"]

# === File Storage ===
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=20

# === ERP Push Integration ===
# Fill these in when ERP credentials are available.
# The "Push to ERP" button is safely disabled when these are blank.
ERP_BASE_URL=
ERP_API_KEY=
ERP_TIMEOUT_SECONDS=30

# === Azure OpenAI (alternative to standard OpenAI) ===
# Set all three to switch from standard OpenAI to Azure OpenAI.
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# === Azure Blob Storage (optional — local filesystem used when blank) ===
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER_NAME=uploads
